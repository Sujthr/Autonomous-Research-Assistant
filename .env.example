# ── LLM Gateway V3 ────────────────────────────────────────────────────────────
# URL where the gateway is running (default: http://localhost:8101)
LLM_GATEWAY_V3_URL=http://localhost:8101

# Provider API keys — add at least ONE worker provider key
GEMINI_API_KEY=              # Recommended: free tier, 1M context window
GROQ_API_KEY=                # Fast inference, good free tier
CEREBRAS_API_KEY=            # Very fast, free tier
NVIDIA_API_KEY=              # NVIDIA NIM models
OPEN_ROUTER_API_KEY=         # Multi-model routing
GITHUB_ACCESS_TOKEN=         # GitHub Models (gpt-4.1-mini etc.)
OLLAMA_MODEL=                # Local model name (e.g. llama3.2) if using Ollama
OLLAMA_URL=http://localhost:11434

# Optional: override specific worker models
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=openai/gpt-oss-120b

# ── MCP Server (web_search + fetch_url) ───────────────────────────────────────
TAVILY_API_KEY=              # Required for web search (DuckDuckGo is the fallback)
